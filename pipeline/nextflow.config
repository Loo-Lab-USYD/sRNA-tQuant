/*
 * tRNA Isodecoder Quantification Pipeline – Configuration
 */

// Default parameters
params {
    // --- Input / Output ---
    input               = null          // Path to samplesheet CSV
    outdir              = './results'
    genome_fasta        = null          // Genome FASTA (triggers de-novo reference build)
    trna_reference      = null          // Pre-built reference bundle directory

    // --- Optional rRNA depletion ---
    rrna_index          = null          // Bowtie2 index for rRNA removal (null = skip)

    // --- Quantification ---
    quantifier          = 'salmon'      // 'salmon' (recommended) or 'decision' (legacy)
    span_weighted       = false         // Blend Salmon with anticodon-spanning reads (experimental)
    rpm_clamp_threshold = 1000          // Zero out anticodons below this RPM (removes tRF noise); 0 to disable

    // --- Modification calling ---
    skip_modification_calling = true    // Disabled: mod redistribution hurts correlation vs gold standard

    // --- Trimming (fastp) ---
    min_length          = 10
    max_length_se       = 100
    max_length_pe       = 125
    adapter_sequence    = null                       // null = fastp auto-detect (Illumina universal)

    // --- Alignment (Bowtie2) ---
    // Anticodon-level resolution (default): -L 14 -D 25
    // Transcript-level resolution (conservative): -L 18 -D 50
    bowtie2_seed_length = 14
    bowtie2_seed_extensions = 25

    // --- tRNAscan-SE ---
    trnascan_thread     = 4

    // --- Pre-tRNA extraction ---
    flank               = 50            // Flanking nt for pre-tRNA extraction

    // --- Resource defaults ---
    max_memory          = '16.GB'
    max_cpus            = 8
    max_time            = '24.h'

    // --- Gadi (NCI) ---
    gadi_project        = null         // e.g. 'ab12'
    gadi_storage        = null         // e.g. 'gdata/ab12+scratch/ab12'
}

// Process-level configuration
process {
    // Default resources
    cpus   = 1
    memory = '2.GB'
    time   = '2.h'

    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
        time   = '8.h'
    }

    withLabel: 'process_medium' {
        cpus   = 8
        memory = '8.GB'
        time   = '8.h'
    }

    withLabel: 'process_high' {
        cpus   = params.max_cpus
        memory = params.max_memory
        time   = '24.h'
    }

    // Bowtie2 alignment parameters via ext.args (nf-core pattern)
    withName: 'MAP_ARTIFICIAL' {
        ext.args = "-L ${params.bowtie2_seed_length} -D ${params.bowtie2_seed_extensions} --no-unal"
    }

    withName: 'MAP_CLUSTERS' {
        ext.args = "-L ${params.bowtie2_seed_length} -D ${params.bowtie2_seed_extensions} --no-unal"
    }

    withName: 'SALMON_QUANT' {
        ext.args = '--numBootstraps 100 --minAssignedFrags 1'
    }
}

// Profiles
profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'trna-mapping:latest'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${projectDir}/../singularity_cache"
        process.container = "${projectDir}/../trna-mapping.sif"
    }

    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }

    local {
        // No container – tools must be in PATH
        executor.name = 'local'
    }

    gadi {
        // NCI Gadi (PBS Pro)
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${projectDir}/../singularity_cache"
        process.container = "${projectDir}/../trna-mapping.sif"

        process.executor = 'pbspro'
        process.queue = 'normal'
        process.project = params.gadi_project ?: ''
        process.storage = params.gadi_storage ?: ''

        process {
            withLabel: 'process_low' {
                cpus   = 1
                memory = '4.GB'
                time   = '2.h'
            }
            withLabel: 'process_medium' {
                cpus   = 4
                memory = '16.GB'
                time   = '8.h'
            }
            withLabel: 'process_high' {
                cpus   = 8
                memory = '32.GB'
                time   = '24.h'
            }
        }
    }

    test {
        params {
            input       = "${projectDir}/../tests/fixtures/samplesheet.csv"
            genome_fasta = null
            trna_reference = "${projectDir}/../tests/fixtures/test_reference"
            outdir      = './test_results'
            quantifier  = 'salmon'
            skip_modification_calling = true
            max_cpus    = 2
            max_memory  = '4.GB'
        }
    }
}

// Pipeline info
manifest {
    name            = 'tRNA-mapping'
    author          = 'Labhund'
    description     = 'tRNA isodecoder quantification from small RNA-seq data'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.1.0'
}

// Execution reports
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}
